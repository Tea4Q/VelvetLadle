# EAS Build Ignore File
# Exclude files that aren't needed for the build process

# Version control
.git/
.gitignore
.gitattributes

# Dependencies (will be installed on build server)
node_modules/
.pnp
.pnp.js

# Build outputs
build/
dist/
.expo/
.expo-shared/
*.log

# Testing
coverage/
.nyc_output/
__tests__/
*.test.js
*.test.ts
*.test.tsx
*.spec.js
*.spec.ts
*.spec.tsx

# Documentation (not needed for build)
docs/
*.md
!README.md

# Scripts that aren't needed for build
scripts/create-test-accounts.js
scripts/manage-recipe-ownership.js
scripts/seed-demo-recipes.js
scripts/check-database.js
scripts/test-guest-access.js
scripts/move-recipes-to-user.js
scripts/auto-doc.js

# Database files
*.sql
database/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment files (secrets handled separately)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temporary files
tmp/
temp/
*.tmp

# Large media files (if any)
assets/videos/
*.mp4
*.mov

# Android/iOS build artifacts (if present)
android/app/build/
android/.gradle/
ios/build/
ios/Pods/

# Misc
.cache/
*.bak
*.swp

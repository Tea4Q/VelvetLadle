{
  "name": "velvetladle",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "npx expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "commit": "git-cz",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "docs:auto": "node scripts/auto-doc.js",
    "check-deps": "node scripts/check-deps.js",
    "setup-images": "node scripts/setup-image-storage.js",
    "prebuild": "node scripts/cleanup-logs.js",
    "build:preview": "npx eas build --profile preview --platform android",
    "build:production": "npx eas build --profile production --platform android",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "postinstall": "node scripts/fix-rns-screen.js"
  },
  "expo": {
    "plugins": [
      "expo-font"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@supabase/supabase-js": "^2.97.0",
    "babel-plugin-module-resolver": "5.0.2",
    "expo": "~55.0.9",
    "expo-application": "~55.0.12",
    "expo-blur": "~55.0.12",
    "expo-build-properties": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-device": "~55.0.12",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.16",
    "expo-json-utils": "~55.0.0",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.13",
    "expo-updates": "~55.0.18",
    "expo-web-browser": "~55.0.12",
    "posthog-react-native": "^4.37.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-purchases": "^9.10.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.1.0",
    "commitizen": "^4.2.4",
    "conventional-changelog-cli": "^4.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
